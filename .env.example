# ============================================
# MyAPI 环境变量配置
# 复制此文件为 .env 后修改
# ============================================

# ---- 运行模式 ----
# local = SQLite（零依赖，个人/开发使用）
# cloud = MySQL（高并发，生产环境）
DEPLOY_MODE=local

# ---- 基础配置 ----
# 服务端口
NEW_API_PORT=3000

# ---- 数据库配置（仅 cloud 模式需要）----
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_DATABASE=newapi
# MYSQL_USER=newapi
# MYSQL_PASSWORD=ChangeMe123!
# MYSQL_ROOT_PASSWORD=RootPassword123!

# 数据库连接字符串（cloud 模式直接使用此变量）
# SQL_DSN=user:password@tcp(127.0.0.1:3306)/newapi?charset=utf8mb4&parseTime=True&loc=Local

# ---- Redis（可选，高并发推荐）----
# REDIS_CONN_STRING=redis://localhost:6379/0

# ---- 会话与加密密钥 ----
# 多机部署必须设置，确保各节点一致
# SESSION_SECRET=your-session-secret
# CRYPTO_SECRET=your-crypto-secret

# ---- 时区 ----
TZ=Asia/Shanghai

# ---- 流式与请求限制 ----
# STREAMING_TIMEOUT=300
# MAX_REQUEST_BODY_MB=32

# ---- 调试 ----
# DEBUG=true
# ERROR_LOG_ENABLED=true
